{
  "name": "reactive-agent-pay",
  "version": "1.0.0",
  "description": "Reactive AI agent service marketplace with Somnia Reactivity and x402 micropayments",
  "main": "dist/server/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server/index.js",
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc",
    "demo:consumer": "tsx examples/demo-consumer.ts",
    "demo:provider": "tsx examples/demo-provider.ts",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\""
  },
  "keywords": [
    "somnia",
    "reactivity",
    "x402",
    "micropayments",
    "ai-agents",
    "blockchain",
    "base",
    "usdc"
  ],
  "author": "Sovereign Agent",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
